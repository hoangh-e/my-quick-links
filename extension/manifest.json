{
  "manifest_version": 3,
  "name": "My Quick Links",
  "version": "1.0.0",
  "description": "Quick access to my personal web links.",
  "permissions": ["storage"],
  "host_permissions": ["https://hoangh-e.github.io/*"],
  "action": {
    "default_title": "My Quick Links",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
